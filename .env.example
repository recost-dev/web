# Copy to .env.local and fill in values

# Backend API base URL (defaults to https://api.recost.dev if unset)
VITE_API_URL=https://api.recost.dev

# Google OAuth client ID (required for sign-in)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Set to "true" to bypass auth and use mock data locally
VITE_DEV_AUTH=true

# Email address allowed to access the Auto Parser page
# Leave unset to disable the gate (any authenticated user can access)
VITE_ALLOWED_EMAIL=your-email@gmail.com
